# Database provider
APP_DATABASE_PROVIDER=supabase

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# WeChat login provider
# native | arsn
WECHAT_LOGIN_PROVIDER=arsn

# Native WeChat OAuth
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# ARSN aggregated login
ARSN_LOGIN_APP_ID=
ARSN_LOGIN_APP_KEY=
# Optional: wx | wxmp
ARSN_WECHAT_LOGIN_TYPE=wx

# WeChat OAuth callback URL
WECHAT_OAUTH_CALLBACK_URL=https://your-landing-domain/auth/wechat/callback

# SMS provider
# dev | juhe
SMS_PROVIDER=dev

# Juhe SMS
JUHE_SMS_API_KEY=
JUHE_SMS_TPL_ID=
JUHE_SMS_SIGN=
