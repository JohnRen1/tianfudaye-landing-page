# Database provider
APP_DATABASE_PROVIDER=supabase

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Native WeChat OAuth
# Get these from WeChat Official Account platform
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# WeChat OAuth callback URL
WECHAT_OAUTH_CALLBACK_URL=https://your-landing-domain/auth/wechat/callback

# SMS provider
# dev | juhe
SMS_PROVIDER=dev

# Juhe SMS
JUHE_SMS_API_KEY=
JUHE_SMS_TPL_ID=
JUHE_SMS_SIGN=
