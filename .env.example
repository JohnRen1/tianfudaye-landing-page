# Runtime stage
APP_ENV=dev

# Database provider
APP_DATABASE_PROVIDER=supabase

# Auth bypass for current integration stage
AUTH_BYPASS_ENABLED=false
AUTH_BYPASS_USER_PHONE=18660396808
NEXT_PUBLIC_AUTH_BYPASS_ENABLED=false
NEXT_PUBLIC_AUTH_BYPASS_USER_PHONE=18660396808

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Native WeChat OAuth
# Get these from WeChat Official Account platform
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# WeChat OAuth callback URL
WECHAT_OAUTH_CALLBACK_URL=https://your-landing-domain/auth/wechat/callback

# RAG chat service
RAG_CHAT_URL=http://127.0.0.1:8000/chat
RAG_CHAT_TOP_K=6
RAG_CHAT_RETURN_DEBUG=true
RAG_CHAT_TIMEOUT_MS=60000

# SMS provider
# dev | juhe
SMS_PROVIDER=dev

# Juhe SMS (模板：【天赋大业教育科技】您的验证码是#code#。如非本人操作，请忽略本短信)
JUHE_SMS_API_KEY=
JUHE_SMS_TPL_ID=
